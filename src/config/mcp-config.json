{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-playwright"],
      "description": "Browser automation and UI exploration"
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "Git operations and PR creation"
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\Users\\kamboja1\\Downloads\\ai-driven-testing-playwright-webinar"
      ],
      "description": "File system operations"
    }
  },
  "agentConfiguration": {
    "supervisor": {
      "enabled": true,
      "timeout": 300000
    },
    "browserAgent": {
      "enabled": true,
      "headless": false,
      "captureSnapshots": true
    },
    "patchAgent": {
      "enabled": true,
      "formatCode": true
    },
    "runnerAgent": {
      "enabled": true,
      "workers": 1
    },
    "gitAgent": {
      "enabled": false,
      "autoPush": false,
      "createPR": false
    }
  }
}
